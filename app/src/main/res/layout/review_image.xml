<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/root"
    android:background="@drawable/camera_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <include
        android:id="@id/control_bar"
        layout="@layout/review_control" />
    <FrameLayout
        android:background="@drawable/border_view_finder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="13.0dip"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true">
        <RelativeLayout
            android:id="@id/mainPanel"
            android:layout_width="384.0dip"
            android:layout_height="288.0dip"
            android:layout_toLeftOf="@id/button_bar">
            <AbsoluteLayout
                android:id="@id/slideShowContainer"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <com.techno.gallery.ImageViewTouch2
                    android:id="@id/image1_slideShow"
                    android:background="#00000000"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" />
                <com.techno.gallery.ImageViewTouch2
                    android:id="@id/image2_slideShow"
                    android:background="#00000000"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" />
            </AbsoluteLayout>
            <AbsoluteLayout
                android:id="@id/abs"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <com.techno.gallery.ImageViewTouch2
                    android:id="@id/image"
                    android:background="#ff000000"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" />
            </AbsoluteLayout>
            <ImageView
                android:id="@id/prev_image"
                android:focusable="true"
                android:visibility="invisible"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:src="@drawable/btn_camera_arrow_left"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true" />
            <ImageView
                android:id="@id/next_image"
                android:focusable="true"
                android:visibility="invisible"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:src="@drawable/btn_camera_arrow_right"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>
    </FrameLayout>
</RelativeLayout>